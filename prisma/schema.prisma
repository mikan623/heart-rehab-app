// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id  // LINE userId または メールアドレス
  email          String   @unique
  name           String?
  password       String?  // メール登録ユーザー用（ハッシュ化）
  authType       String   @default("line")  // "line" または "email"
  role           String   @default("patient") // 🆕 "patient" | "medical"
  lineConnected  Boolean  @default(false)  // 🆕 LINE 連携状態
  lineUserId     String?  @unique          // 🆕 LINE Messaging API ユーザーID
  selfLinkCode   String?  @unique          // 🆕 本人用招待コード（公式アカとのひも付け用）
  reminderEnabled Boolean  @default(false) @map("reminder_enabled") // 🆕 記録忘れリマインダー有効フラグ
  reminderTime    String?               @map("reminder_time")      // 🆕 記録忘れリマインダー時刻（HH:MM, Asia/Tokyo）
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // リレーション
  profiles      Profile[]
  passwordResetTokens PasswordResetToken[]
  healthRecords HealthRecord[]
  familyMembers FamilyMember[]
  familyInvites FamilyInvite[]
  bloodData     BloodData[]
  // 医療従事者 ↔ 患者 招待（承認）
  providerInvites MedicalInvite[] @relation("ProviderInvites")
  patientInvites  MedicalInvite[] @relation("PatientInvites")
  // 医療コメント（医療従事者→患者）
  providerComments MedicalComment[] @relation("ProviderComments")
  patientComments  MedicalComment[] @relation("PatientComments")
  // 検査コメント（血液/CPX）
  providerLabComments MedicalLabComment[] @relation("ProviderLabComments")
  patientLabComments  MedicalLabComment[] @relation("PatientLabComments")
  
  @@map("users")
}

model MedicalInvite {
  id         String   @id @default(cuid())
  providerId String
  patientId  String
  status     String   @default("pending") // pending | accepted | declined
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  provider User @relation("ProviderInvites", fields: [providerId], references: [id], onDelete: Cascade)
  patient  User @relation("PatientInvites", fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([providerId, patientId])
  @@map("medical_invites")
}

model Profile {
  id                     String   @id @default(cuid())
  userId                 String
  displayName            String?
  age                    Int?
  gender                 String?
  height                 Float?
  targetWeight           Float?
  diseases               String[]
  riskFactors            String[]
  medications            String?
  physicalFunction       String?
  emergencyContact       String?  // 緊急連絡先
  securityQuestionAnswer String?  // セキュリティ質問の答え
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("profiles")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("password_reset_tokens")
}

model HealthRecord {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  date                  String   @db.Text
  time                  String
  bloodPressureSystolic Int      @map("blood_pressure_systolic")
  bloodPressureDiastolic Int     @map("blood_pressure_diastolic")
  pulse                 Int?
  weight                Float?
  exercise              Json?    // { type: string, duration: string }
  meal                  Json?    // { staple: string[], mainDish: string[], sideDish: string[], other: string }
  dailyLife             String?  @map("daily_life")
  medicationTaken       Boolean? @map("medication_taken")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt      @map("updated_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicalComments MedicalComment[]
  
  @@map("health_records")
}

model MedicalComment {
  id            String   @id @default(cuid())
  providerId    String
  patientId     String
  healthRecordId String
  content       String   @db.Text
  createdAt     DateTime @default(now())

  provider    User        @relation("ProviderComments", fields: [providerId], references: [id], onDelete: Cascade)
  patient     User        @relation("PatientComments", fields: [patientId], references: [id], onDelete: Cascade)
  healthRecord HealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@index([providerId, createdAt])
  @@map("medical_comments")
}

model FamilyMember {
  id           String   @id @default(cuid())
  userId       String
  name         String
  email        String   // 🆕 メールアドレス
  relationship String
  lineUserId   String?
  isRegistered Boolean  @default(false)
  linkCode     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("family_members")
  @@unique([userId, email])
  @@unique([userId, lineUserId])
  @@unique([userId, linkCode])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  category  String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model FamilyInvite {
  id        String   @id @default(cuid())
  patientId String
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)

  patient   User     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("family_invites")
}

model BloodData {
  id                    String   @id @default(cuid())
  userId                String
  testDate              String   // 検査日
  hbA1c                 Float?   // HbA1c
  randomBloodSugar      Float?   // 随時血糖
  totalCholesterol      Float?   // 総コレステロール
  triglycerides         Float?   // 中性脂肪
  hdlCholesterol        Float?   // HDLコレステロール
  ldlCholesterol        Float?   // LDLコレステロール
  bun                   Float?   // BUN
  creatinine            Float?   // Cr（クレアチニン）
  uricAcid              Float?   // 尿酸
  hemoglobin            Float?   // ヘモグロビン
  bnp                   Float?   // BNP
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cpxTests          CardiopulmonaryExerciseTest[]
  labComments       MedicalLabComment[]

  @@map("blood_data")
}

model CardiopulmonaryExerciseTest {
  id                       String   @id @default(cuid())
  bloodDataId              String
  testDate                 String   // 検査日
  cpxRound                 Int      // 何回目か（1、2など）
  atOneMinBefore           Float?   // AT1分前
  atDuring                 Float?   // AT中
  maxLoad                  Float?   // 最大負荷時
  loadWeight               Float?   // 負荷量(W)
  vo2                      Float?   // VO2(ml/min/kg)
  mets                     Float?   // Mets
  heartRate                Float?   // 心拍数(bpm)
  systolicBloodPressure    Float?   // 収縮期血圧(mmHg)
  findings                 String?  // 所見
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  bloodData BloodData @relation(fields: [bloodDataId], references: [id], onDelete: Cascade)
  labComments MedicalLabComment[]

  @@map("cardiopulmonary_exercise_tests")
}

model MedicalLabComment {
  id        String   @id @default(cuid())
  providerId String
  patientId  String
  bloodDataId String?
  cpxTestId   String?
  content   String   @db.Text
  createdAt DateTime @default(now())

  provider User @relation("ProviderLabComments", fields: [providerId], references: [id], onDelete: Cascade)
  patient  User @relation("PatientLabComments", fields: [patientId], references: [id], onDelete: Cascade)
  bloodData BloodData? @relation(fields: [bloodDataId], references: [id], onDelete: Cascade)
  cpxTest   CardiopulmonaryExerciseTest? @relation(fields: [cpxTestId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@index([providerId, createdAt])
  @@map("medical_lab_comments")
}

